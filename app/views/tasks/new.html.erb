<h1>New Task</h1>
<%= form_with model: @task, local: true do |form| %>
  <p>Title: <%= form.text_field :title %></p>
  <p>Description: <%= form.text_area :description %></p>
  <p>Completed: <%= form.check_box :completed %></p>
  <%= form.submit "Create Task" %>
<% end %>
<%= link_to "Back", tasks_path %>
